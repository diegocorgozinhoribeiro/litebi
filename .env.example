# ===== LiteBI — variáveis de ambiente =====

# Conexão do Postgres (Neon). Use a connection string do painel do Neon.
# IMPORTANTE: nunca versione o .env real. Rotacione a senha se ela vazar.
DATABASE_URL=postgresql://USUARIO:SENHA@HOST.neon.tech/neondb?sslmode=require

# Segredo da sessão (gere um valor aleatório longo).
# Ex.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=cole-aqui-um-valor-aleatorio-bem-longo

# URL pública do site (sem barra no final). Necessária para o callback do Google.
# Em produção no Render, algo como: https://litebi.onrender.com
BASE_URL=http://localhost:3000

# Define cookies seguros e modo de produção. Use 'production' no Render.
NODE_ENV=development

# Porta (o Render injeta automaticamente; localmente usa 3000).
PORT=3000

# ===== Google OAuth (opcional) =====
# Crie credenciais em https://console.cloud.google.com/apis/credentials
# Origem autorizada: a sua BASE_URL
# URI de redirecionamento autorizada: BASE_URL + /auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# IA OpenAI. Nunca coloque esta chave no frontend ou no Git.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
